{
  "name": "booking-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fresh": "powershell -Command \"Get-Process -Name node -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Sleep -Seconds 2; if (Test-Path .next) { Remove-Item -Recurse -Force .next }\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "deploy": "vercel --prod",
    "firebase:deploy": "firebase deploy",
    "firebase:emulate": "firebase emulators:start"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@line/bot-sdk": "^10.6.0",
    "@line/liff": "^2.27.3",
    "@stripe/stripe-js": "^8.8.0",
    "canvas": "^3.2.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.6.0",
    "firebase-admin": "^13.7.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.575.0",
    "next": "^14.2.35",
    "omise": "^0.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "recharts": "^2.15.4",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
